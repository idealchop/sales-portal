
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Match the path where user avatars are stored.
    // The path contains the user's unique ID (userId).
    match /user-avatars/{userId}/{allPaths=**} {

      // Allow anyone to read the images. Profile pictures are typically public.
      allow read;

      // Allow write operations (create, update, delete) only if the user
      // is authenticated AND their user ID matches the {userId} in the path.
      // This ensures users can only modify their own avatars.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
