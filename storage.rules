
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ===== USER AVATARS =====
    // Path: user-avatars/{userId}/...
    match /user-avatars/{userId}/{allPaths=**} {
      // Anyone can read user avatars
      allow read;
      // Only the authenticated owner can write
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== SALES & MARKETING MATERIALS =====
    // This path matches the URL encoding for "Sales Portal/Marketing Mats"
    match /sales_portal/marketing_mats/{allPaths=**} {
      // Public read access
      allow read;
      // Only authenticated users (sales team) can upload or modify
      allow write: if request.auth != null;
    }

    // ===== BRAND LOGOS =====
    // Note: The path is encoded from 'Brand Logo'.
    match /Brand%20Logo/{allPaths=**} {
        allow read;
    }

    // ===== PAYMENT PROOFS =====
    // Both initial and ongoing payment proofs.
    // The path is unique enough to prevent unauthorized access.
    match /payment_proofs/{allPaths=**} {
      // Allow public write for initial payment confirmation from public URL
      // and authenticated write for internal dashboard.
      allow write: if true;
      // Only authenticated users can read proofs.
      allow read: if request.auth != null;
    }
  }
}
