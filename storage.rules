
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ===== USER AVATARS =====
    // Path: user-avatars/{userId}/...
    match /user-avatars/{userId}/{allPaths=**} {
      // Anyone can read user avatars
      allow read;
      // Only the authenticated owner can write
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== SALES & MARKETING MATERIALS =====
    // This path matches the URL encoding for "Sales Portal/Marketing Mats"
    match /Sales Portal/Marketing Mats/{allPaths=**} {
      // Public read access for all sales and marketing materials.
      allow read;
      // Only authenticated users (e.g. sales team) can upload or modify.
      allow write: if request.auth != null;
    }
    
    // Allow public read for brand logos
    match /Brand Logo/{allPaths=**} {
        allow read;
    }

    // ===== PAYMENT PROOFS =====
    // Path: payment_proofs/{clientId}/{proposalId}/{fileName}
    match /payment_proofs/{clientId}/{proposalId}/{allPaths=**} {
      // Allow read and write access for any authenticated user (sales agents)
      allow read, write: if request.auth != null;
    }
  }
}
