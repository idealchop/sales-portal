
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ===== USER AVATARS =====
    // Path: user-avatars/{userId}/...
    match /user-avatars/{userId}/{allPaths=**} {
      // Anyone can read user avatars
      allow read;
      // Only the authenticated owner can write
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== SALES & MARKETING MATERIALS =====
    // This path matches the URL encoding for "Sales Portal/Marketing Mats"
    match /sales_portal/marketing_mats/{allPaths=**} {
      // Public read access
      allow read;
      // Only authenticated users (sales team) can upload or modify
      allow write: if request.auth != null;
    }

    // ===== BRAND LOGOS =====
    // Path: /Brand%20Logo/ for public read access
    match /'Brand Logo'/{allPaths=**} {
        allow read;
    }

    // ===== PAYMENT PROOFS =====
    // Initial proposal payment proof
    match /payment_proofs/{clientId}/{proposalId}/{allPaths=**} {
      // Allow public write for initial payment confirmation
      allow write: if true;
      // Only authenticated users can read
      allow read: if request.auth != null;
    }

    // Recurring subscription payments (admin dashboard)
    match /payment_proofs/{clientId}/ongoing/{allPaths=**} {
      // Authenticated users only
      allow read, write: if request.auth != null;
    }
  }
}
