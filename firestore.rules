
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Allow sales users to read other sales user profiles for display purposes
    match /sales/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }
    
    match /counters/{counterId} {
      allow read, write: if isSignedIn(); // For ID generation
    }

    match /sales_materials/{materialId} {
      allow get: if true; // Public read for all materials
      allow list, write: if false; // TBD: admin-only write access
    }

    // Commissions can only be read/written by the user they belong to.
    match /commissions/{commissionId} {
        allow read, write: if request.auth.uid == resource.data.userId;
    }

    // A user can read a client if they have created a proposal for that client.
    // This is a simplified rule; a more robust solution might use custom claims or a user-to-client mapping.
    // For now, we allow any signed-in user to read client docs, but hooks will filter them.
    // Write access is also open but should be locked down further in a real-world scenario.
    match /clients/{clientId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
      
      // Proposals can only be read by their owner.
      match /proposals/{proposalId} {
        allow read, create, update: if isSignedIn() && request.auth.uid == resource.data.userId;
        allow delete: if false;
      }
      
      match /remarks/{remarkId} {
        allow read, create: if isSignedIn();
      }
    }
    
    // This is a workaround for CollectionGroup queries.
    // It allows a user to query the 'proposals' collection group,
    // but the `where('userId', '==', request.auth.uid)` clause in the client-side
    // query is what actually enforces the security.
    match /{path=**}/proposals/{proposalId} {
       allow read: if isSignedIn();
    }
  }
}
