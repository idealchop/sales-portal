
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // This rule allows the collectionGroup query in useProposals.ts to work.
    // It allows any signed-in user to list documents across all 'proposals' subcollections.
    match /{path=**}/proposals/{proposalId} {
      allow read, list: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;

      // This rule handles direct access to a specific proposal.
      // The rule above handles the collection group query.
      match /proposals/{proposalId} {
        allow read, create, update: if isSignedIn();
        allow delete: if false;
      }
      
      match /remarks/{remarkId} {
        allow read, create: if isSignedIn();
      }
    }

    match /sales_materials/{materialId} {
      allow get: if true;
      allow list, write: if false;
    }
    
    match /commissions/{commissionId} {
        allow read, write: if request.auth.uid == resource.data.userId;
    }

    match /sales/{userId} {
      // Allow any signed-in user to read sales profiles to display names
      allow read: if isSignedIn();
      // Only the owner can create or update their own profile
      allow create, update: if request.auth.uid == userId;
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }
  }
}
