
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Allow user with this specific email to be admin
      return request.auth.token.email == 'admin@smartrefill.io';
    }

    function isManager() {
      return get(/databases/$(database)/documents/sales/$(request.auth.uid)).data.role == 'manager';
    }

    function isSalesManagerOf(userId) {
        let managerProfile = get(/databases/$(database)/documents/sales/$(request.auth.uid)).data;
        let userProfile = get(/databases/$(database)/documents/sales/$(userId)).data;
        let managerTeamName = managerProfile.location + " (" + managerProfile.displayName + ")";
        return userProfile.team == managerTeamName;
    }

    // Sales users can read other profiles for display purposes. Admin can read all.
    match /sales/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }
    
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /sales_materials/{materialId} {
      allow get: if true; // Public read for all materials
      allow list, write: if isAdmin(); 
    }

    // Admin can read all commissions. Users can only read/write their own.
    match /commissions/{commissionId} {
        allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
        allow write: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // Any signed-in user can read client and proposal data.
    // Writes are more restricted.
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if false;
      
      match /proposals/{proposalId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(request.resource.data.userId);
        allow update: if isSignedIn() && isOwner(resource.data.userId);
        allow delete: if false;
      }
      
      // Remarks can be read and created by any signed-in user for any client.
      match /remarks/{remarkId} {
        allow read, create: if isSignedIn();
      }
    }
    
    // This allows admin or managers to perform a collectionGroup query on 'proposals'
    match /{path=**}/proposals/{proposalId} {
      allow list: if isSignedIn() && (isAdmin() || isManager());
    }
    
    // This allows admin or managers to perform a collectionGroup query on 'clients'
    match /{path=**}/clients/{clientId} {
      allow list: if isSignedIn() && (isAdmin() || isManager());
    }

    // Rules for user-specific notifications
    match /users/{userId}/notifications/{notificationId} {
      // Only the owner of the notifications can read or write them.
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
