
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Allow sales users to read other sales user profiles for display purposes
    match /sales/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }
    
    match /counters/{counterId} {
      allow read, write: if isSignedIn(); // For ID generation
    }

    match /sales_materials/{materialId} {
      allow get: if true; // Public read for all materials
      allow list, write: if false; // TBD: admin-only write access
    }

    // Commissions can only be read/written by the user they belong to.
    match /commissions/{commissionId} {
        allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // A user can read/write a client document if they are the owner.
    match /clients/{clientId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
      
      // Proposals can only be read or written by their owner.
      match /proposals/{proposalId} {
        allow read, create, update: if isSignedIn() && request.auth.uid == resource.data.userId;
        allow delete: if false;
      }
      
      match /remarks/{remarkId} {
        allow read, create: if isSignedIn();
      }
    }
  }
}
