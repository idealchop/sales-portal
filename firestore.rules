
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Allow sales users to read other sales user profiles for display purposes
    match /sales/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }
    
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /sales_materials/{materialId} {
      allow get: if true; // Public read for all materials
      allow list, write: if false; // TBD: admin-only write access
    }

    // Commissions can only be read/written by the user they belong to.
    match /commissions/{commissionId} {
        allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Any signed-in user can read client documents, but only the owner can write.
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(resource.data.userId);
      allow delete: if false;
      
      // Any signed-in user can read proposals, but only the owner can write.
      match /proposals/{proposalId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(request.resource.data.userId);
        allow update: if isSignedIn() && isOwner(resource.data.userId);
        allow delete: if false;
      }
      
      // Remarks can be read and created by any signed-in user for any client.
      match /remarks/{remarkId} {
        allow read, create: if isSignedIn();
      }
    }
  }
}
