
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Allow user with this specific email to be admin
      return request.auth.token.email == 'admin@smartrefill.io';
    }

    function isManager() {
      return get(/databases/$(database)/documents/sales/$(request.auth.uid)).data.role == 'manager';
    }

    function isSalesManagerOf(userId) {
        let managerProfile = get(/databases/$(database)/documents/sales/$(request.auth.uid)).data;
        let userProfile = get(/databases/$(database)/documents/sales/$(userId)).data;
        let managerTeamName = managerProfile.location + " (" + managerProfile.displayName + ")";
        return userProfile.team == managerTeamName;
    }

    // Correctly check if the request is for a proposal linked by a valid shareable_links document
    function isReadingSharedProposal(proposalId, clientId) {
      // The linkId must be passed as a query parameter from the client-side fetch
      let linkId = request.query.linkId;
      if (linkId == null) {
        return false;
      }
      
      let linkDoc = get(/databases/$(database)/documents/shareable_links/$(linkId));
      
      // Check if the link exists, is not expired, and matches the requested proposal and client
      return linkDoc != null &&
             linkDoc.data.expiresAt > request.time &&
             linkDoc.data.proposalId == proposalId &&
             linkDoc.data.clientId == clientId;
    }

    match /sales/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();

      match /qr_campaigns/{campaignId} {
        allow read, write: if isSignedIn() && isOwner(userId) && isManager();
      }
    }
    
    match /counters/{counterId} {
      allow read, write;
    }

    match /sales_materials/{materialId} {
      allow get: if true; 
      allow list, write: if isAdmin(); 
    }
    
    match /shareable_links/{linkId} {
      allow get: if true; // Public read to verify the link
      allow create: if isSignedIn(); // Only authenticated users can create links
      allow list, update, delete: if false; // Links are immutable from the client
    }
    
    match /proposals/{proposalId} {
        allow read: if isSignedIn() || isReadingSharedProposal(proposalId, resource.data.clientId);
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin() || isManager());
        allow delete: if false;
    }

    match /commissions/{commissionId} {
        allow read: if isSignedIn() && (isAdmin() || isOwner(resource.data.userId) || (isManager() && isSalesManagerOf(resource.data.userId)));
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isOwner(resource.data.userId));
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() || isReadingSharedProposal(request.resource.data.proposals[0].id, clientId);
      allow list: if isSignedIn();
      allow create;
      allow update: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin() || isManager());
      allow delete: if false;
      
      match /remarks/{remarkId} {
        allow read, create: if isSignedIn();
      }
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
