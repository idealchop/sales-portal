{
  "name": "sales-portal",
  "version": "2.0.0",
  "private": true,
  "description": "Smart Refill Sales Portal monorepo",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:frontend": "npm run dev --prefix frontend -- -p 9002",
    "dev:api": "npm run serve:local --prefix backend/functions",
    "build": "npm run build --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend/functions",
    "build:all": "npm run build:backend && npm run build:frontend",
    "start": "npm run start --prefix frontend -- -p ${PORT:-9002} -H 0.0.0.0",
    "lint": "npm run lint --prefix frontend",
    "test:unit:backend": "npm run test:unit --prefix backend/functions",
    "test:unit:frontend": "npm run test:unit --prefix frontend",
    "test:unit": "npm run test:unit:backend && npm run test:unit:frontend",
    "test:bdd:backend": "npm --prefix backend run test:bdd:local",
    "test:bdd:frontend": "npm run test:bdd:local --prefix frontend",
    "test:bdd:local": "bash scripts/test-bdd-local.sh",
    "test:all:local": "npm run test:unit && npm run test:bdd:local",
    "quality-gate": "bash scripts/sp-quality-gate.sh",
    "deploy:hosting": "npx -y firebase-tools deploy --only hosting:sales-river-tech --project aquaflow-management-suite"
  }
}
