# Copy to .env.local — never commit secrets

NEXT_PUBLIC_DEV=true

# Firebase client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=aquaflow-management-suite.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aquaflow-management-suite
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=smartrefill-singapore
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIRESTORE_DB=riverdb

# reCAPTCHA v3 (App Check provider — public site key)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# App Check debug token (local dev only — register in Firebase Console → App Check → Manage debug tokens)
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# Sales Portal API (this repo backend)
NEXT_PUBLIC_SALES_PORTAL_API_URL=
NEXT_PUBLIC_SALES_PORTAL_API_URL_DEV=http://127.0.0.1:8071

# SmartRefill V3 API (proxied via /smartrefill on Sales Portal API)
NEXT_PUBLIC_SMARTREFILL_API_URL=
NEXT_PUBLIC_SMARTREFILL_API_URL_DEV=http://127.0.0.1:5001/aquaflow-management-suite/asia-southeast1/smartrefillV3Api

# Smart Refill public app origin (Resources share links; default https://app.smartrefill.io)
NEXT_PUBLIC_SMARTREFILL_APP_URL=https://app.smartrefill.io
