{
  "hosting": {
    "site": "river-tech",
    "public": "frontend/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "sales-portal",
          "region": "asia-southeast1"
        }
      }
    ]
  },
  "apphosting": [
    {
      "backendId": "feature",
      "rootDir": "frontend",
      "ignore": [
        "backend",
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ]
}
