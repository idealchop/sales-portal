
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /user-avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /sales_portal/marketing_mats/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    match /Brand%20Logo/{allPaths=**} {
        allow read;
    }

    match /payment_proofs/{allPaths=**} {
      allow write: if true;
      allow read: if request.auth != null;
    }
  }
}
