# Copy to secrets.env — never commit. Used by ./scripts/set-secrets.sh
#
# Creates / updates Google Cloud Secret Manager entries for Sales Portal.
# Local dev: use backend/functions/.env and frontend/.env.local instead.

FIREBASE_PROJECT=aquaflow-management-suite

# Cloud Functions (salesPortalApi) — separate from SmartRefill GEMINI_API_KEY
SALES_PORTAL_GEMINI_API_KEY=

# Shared with SmartRefill (usually already present in Secret Manager).
# Page token must include pages_manage_posts for webinar automation.
# META_COMMUNITY_PAGE_ACCESS_TOKEN=
# META_COMMUNITY_PAGE_ID=

# App Hosting — optional debug token (register in Firebase Console → App Check)
SALES_PORTAL_APPCHECK_DEBUG_TOKEN=

# Optional — only if not using Application Default Credentials locally
# SALES_PORTAL_FIREBASE_CLIENT_EMAIL=
# SALES_PORTAL_FIREBASE_PRIVATE_KEY=
