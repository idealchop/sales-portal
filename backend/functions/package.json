{
  "name": "sales-portal-api",
  "version": "1.0.0",
  "description": "Sales Portal API — Cloud Functions gateway with SmartRefill integration",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "serve:local": "ts-node-dev --respawn --transpile-only src/local-server.ts",
    "deploy": "firebase deploy --only functions:sales-portal-api",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:bdd": "playwright test",
    "test:all": "npm run test && npm run test:bdd",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@getbrevo/brevo": "^2.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "pdfkit": "^0.15.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.9",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
